# Ignore all contents of /docs by default — but use the directory-glob form
# (/docs/* rather than bare /docs) so git can still descend into selectively
# un-ignored subpaths via the negation pattern below.
/docs/*

# Narrow exception: track the launch-readiness inventory + checklist explicitly.
# Everything else under /docs/ remains untracked per the convention with the
# ~10 local-only agm-*.md siblings (analysis notes, retros, plans).
!/docs/analysis
/docs/analysis/*
!/docs/analysis/agm-outstanding.md
!/docs/analysis/agm-launch-checklist.md
!/docs/analysis/agm-advisor-chain-audit.md
!/docs/analysis/api-endpoint-sync-audit-be-to-fe.md

