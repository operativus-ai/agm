# Agent Manager — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and loaded automatically via spring.config.import.

# Database
DB_PASSWORD=changeme

# Google Genai (Gemini)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_PROJECT_ID=your-google-project-id

# OpenAI (optional — defaults to dummy-test-key if unset)
OPENAI_API_KEY=your-openai-api-key

# Anthropic (optional — defaults to dummy-test-key if unset)
ANTHROPIC_API_KEY=your-anthropic-api-key

# JWT
JWT_ISSUER_URI=https://your-auth-server

# HS256 signing secret for first-party JWTs. REQUIRED in the prod profile (no
# default; Spring fails fast if unset). Generate with: openssl rand -base64 32
# Min length: 32 bytes after base64 decode (HS256 requires 256-bit keys).
JWT_SECRET=replace-with-output-of-openssl-rand-base64-32

# A2A Encryption (generate with: openssl rand -base64 32)
# Only needed if using agent-to-agent networking
# agm.security.outbound-key-encryption-key=your-base64-key

# Cohere (optional — for RAG re-ranking)
# COHERE_API_KEY=your-cohere-api-key
