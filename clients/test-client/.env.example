# Copy to .env (or export in your shell) and source before running the harness.
# tsx/vitest do not auto-load .env — run e.g.:  set -a; source .env; set +a; npm run smoke

# AGM backend base URL (no trailing slash). Node is not subject to CORS — talk to it directly.
AGM_BASE_URL=http://localhost:8080

# ── Identities ───────────────────────────────────────────────────────────────
# admin: unlocks admin lanes. Use a user whose org_id is set (self-registered
# users have null org_id and fail agent-scope resolution). AGM_USERNAME/PASSWORD
# below are the legacy fallback for admin (kept for the standalone smoke.ts).
AGM_ADMIN_USERNAME=
AGM_ADMIN_PASSWORD=
AGM_USERNAME=
AGM_PASSWORD=
# Optional second org (userA + userB) — unlocks the Phase-5 isolation suite.
AGM_USER_A_USERNAME=
AGM_USER_A_PASSWORD=
AGM_USER_B_USERNAME=
AGM_USER_B_PASSWORD=

# Optional: pin the agent to exercise; defaults to the first active agent from discovery.
AGM_AGENT_ID=

# ── Harness controls ─────────────────────────────────────────────────────────
# Cap T2 (LLM) spend in USD; 0 = no ceiling. The runner stops launching LLM
# scenarios once crossed.
AGM_BUDGET_USD=0
# Feature-flag overrides for lanes with no behavioral probe. 1=on, 0=off, unset=skip.
AGM_FLAG_RERANKER=
AGM_FLAG_FINOPS=
# skills / universal-dispatch are probed automatically; override only if needed.
AGM_FLAG_SKILLS=
AGM_FLAG_UNIVERSAL_DISPATCH=

# Set to 1 to enable the live vitest suite (tests/live-smoke.test.ts). Offline parser
# + harness tests always run regardless.
AGM_LIVE=
