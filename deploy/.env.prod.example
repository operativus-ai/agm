# Copy this file to deploy/.env.prod and fill in the values.
# THEN: chmod 600 deploy/.env.prod  (file contains live secrets — must not be world-readable)
#
# This file is sourced by `docker compose --env-file deploy/.env.prod ...`
# at start. Every variable below is consumed by deploy/docker-compose.prod.yml.

# ── Required: TLS + reverse proxy ───────────────────────────────────────────
# DNS hostname pointing at this VM. Caddy uses this to auto-provision a
# Let's Encrypt cert on first start and renew on a 60-day cycle. Use ":80"
# (port-only) to disable TLS for local production-like testing.
DOMAIN=app.example.com

# ── Required: backend secrets ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Must be >= 32 bytes (JwtUtils.validateSecretOrFail rejects shorter values).
JWT_SECRET=

# CORS allowlist for the SPA. Comma-separated origin patterns.
# WebConfig.validateCorsOriginsOrFail refuses to boot with the placeholder.
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://app.example.com

# ── Required: database ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 24
DB_PASSWORD=

# ── Required: outbound-key encryption-at-rest ───────────────────────────────
# Versioned key map used by OutboundApiKeyConverter to encrypt A2A peer API
# keys stored in a2a_remote_agents.outbound_api_key. The prod profile boots
# fail-fast if this is missing. Format: "<version>:<base64-32-bytes>" — add
# more versions comma-separated when rotating; ACTIVE_VERSION selects which
# version encrypts NEW writes (old writes stay decryptable under their own
# version until OutboundApiKeyMigrationService rewrites them).
# Generate a key with: openssl rand -base64 32
AGM_SECURITY_OUTBOUND_KEY_ENCRYPTION_KEYS=1:CHANGE_ME_base64_32_bytes
AGM_SECURITY_OUTBOUND_KEY_ENCRYPTION_ACTIVE_VERSION=1

# ── Required: SMTP (self-serve password reset emails) ───────────────────────
# Without these, password-reset request POSTs accept but fail to deliver the
# email (logged at ERROR; user sees a generic success per the anti-enumeration
# contract). Pick any SMTP relay — SendGrid, Postmark, AWS SES, Mailgun, etc.
# Domain in MAIL_FROM_ADDRESS must be verified at the provider for delivery.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=
MAIL_FROM_ADDRESS=noreply@app.example.com

# Public URL the SPA is served at — embedded in reset-link emails so users land
# on the right /reset-password?token=... screen. Should match DOMAIN (with the
# https:// scheme).
APP_PUBLIC_URL=https://app.example.com

# ── Optional ─────────────────────────────────────────────────────────────────
# Default is "admin" (matches application-prod.properties default).
# DB_USER=admin

# Vertex AI embedding endpoint. Empty if not using Google providers.
# GOOGLE_PROJECT_ID=

# Image tag for the app/web images. With the GitHub Actions pipeline (release.yml)
# this is the short commit SHA the deploy job exports per run; leave it unset here.
# For a manual pull/build you can pin a tag. Defaults to "latest".
# IMAGE_TAG=latest

# Firecrawl base URL for the web-scraping tools (WebScraperTool / FirecrawlSearchTool).
# OPTIONAL — the app health-checks Firecrawl and degrades gracefully if it's absent,
# so scraping is simply unavailable until you stand Firecrawl up. The default points at
# the in-network "firecrawl-api" service from the deploy/docker-compose.firecrawl.yml
# overlay (compose-merge it; see deploy/README.md → "Optional: Firecrawl"). To use a
# remote/separate-VM Firecrawl, set the URL here instead. NOTE: the client sends no auth
# header today, so Firecrawl Cloud (which requires a Bearer key) needs a code change
# first — self-hosted (USE_DB_AUTHENTICATION=false) works as-is.
# APP_FIRECRAWL_BASEURL=http://firecrawl-api:3002

# ── First-admin bootstrap (day-1 only) ───────────────────────────────────────
# Self-registration only grants ROLE_USER and LLM provider keys are admin-gated,
# so a fresh deploy needs an admin to configure anything. Set ENABLED=true plus
# the three credentials for the FIRST boot to auto-create one admin, then set it
# back to false and redeploy. Idempotent: skips if the user already exists.
# ADMIN_BOOTSTRAP_ENABLED=true
# ADMIN_BOOTSTRAP_USERNAME=admin
# ADMIN_BOOTSTRAP_EMAIL=admin@app.example.com
# ADMIN_BOOTSTRAP_PASSWORD=          # min 8 chars; use a strong value
# ADMIN_BOOTSTRAP_ORG_ID=DEFAULT_SYSTEM_ORG
# ADMIN_BOOTSTRAP_ROLE=ROLE_SUPER_ADMIN
