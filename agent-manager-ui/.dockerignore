# Build outputs — produced fresh inside the builder stage.
dist/
build/

# Node deps — npm ci inside the builder restores from package-lock.json
node_modules/

# Test + dev artifacts not needed in the production image
coverage/
.vitest/
*.log
build.log

# IDE / editor / OS noise
.idea/
.vscode/
*.iml
.DS_Store

# Version control + tooling
.git/
.gitignore
.gitattributes
.github/

# Generator scripts + audit scripts (not consumed at runtime)
screenshot-pages.cjs
screenshots/
scripts/audit-api-calls.mjs

# Docs (not consumed at runtime)
*.md
docs/

# Local env files — secrets must never bake into an image layer
.env
.env.*
